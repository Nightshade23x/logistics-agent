# Optional Gemini smart-answer configuration.
# Do not put real keys in this example file.
#
# PowerShell:
# $env:GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# $env:GEMINI_MODEL="gemini-2.5-flash"
#
# The Streamlit frontend works without this key, but custom answers will use
# deterministic fallback text instead of Gemini synthesis.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
